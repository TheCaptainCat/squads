{% if item_spec.category != "roster" %}
{% set owner = authoring_owner(item_type) %}
{% if owner %}
{% set parent = spec.item_parent_required(item_type) %}
{% set subkind = spec.item_subentity_kind(item_type) %}
{% set refkinds = spec.item_ref_rules(item_type) | map(attribute="kind") | list %}
- **{{ owner[1][0] | upper }}{{ owner[1][1:] }}** → `sq create {{ item_type }} "…" --author {{ owner[0] }}`{% if parent and parent in spec.items %} `--parent {{ spec.items[parent].prefix }}-…`{% endif %}{% if subkind %}, then `add-{{ subkind }} "…"`{% if spec.subentity_kinds[subkind].maps_parent_story %} `--story USn`{% endif %}{% endif %}{% if refkinds %}; link with `ref add <id> --kind {{ refkinds | join("|") }}`{% endif %}.
{% endif %}
