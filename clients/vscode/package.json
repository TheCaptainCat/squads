{
  "name": "squads-vscode",
  "displayName": "Squads",
  "description": "Browse a squads-managed project's work items from VS Code.",
  "version": "0.9.0",
  "publisher": "TheCaptainCat",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheCaptainCat/squads"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "configuration": {
      "title": "Squads",
      "properties": {
        "squads.sqPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the sq binary. Takes priority over every other discovery strategy."
        },
        "squads.command": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Full command + argv prefix used to invoke sq (e.g. [\"uv\", \"run\", \"sq\"]). Ignored when squads.sqPath is set."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run format:check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.7",
    "@types/vscode": "^1.125.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
