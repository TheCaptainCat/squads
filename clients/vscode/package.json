{
  "name": "squads-vscode",
  "displayName": "Squads",
  "description": "Browse a squads-managed project's work items from VS Code.",
  "version": "0.9.0",
  "publisher": "TheCaptainCat",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheCaptainCat/squads"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/src/extension.js",
  "activationEvents": [],
  "contributes": {
    "configuration": {
      "title": "Squads",
      "properties": {
        "squads.sqPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the sq binary. Takes priority over every other discovery strategy."
        },
        "squads.command": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Full command + argv prefix used to invoke sq (e.g. [\"uv\", \"run\", \"sq\"]). Ignored when squads.sqPath is set."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "squads",
          "title": "Squads",
          "icon": "resources/squads-icon-mono.svg"
        }
      ]
    },
    "views": {
      "squads": [
        {
          "id": "squadsTree",
          "name": "Work Items"
        }
      ]
    },
    "commands": [
      {
        "command": "squads.refreshTree",
        "title": "Refresh",
        "category": "Squads",
        "icon": "$(refresh)"
      },
      {
        "command": "squads.filterByType",
        "title": "Filter by Type...",
        "category": "Squads"
      },
      {
        "command": "squads.filterByState",
        "title": "Filter by Open/Closed...",
        "category": "Squads"
      },
      {
        "command": "squads.groupBy",
        "title": "Group By...",
        "category": "Squads"
      },
      {
        "command": "squads.clearFiltersAndGrouping",
        "title": "Clear Filters and Grouping",
        "category": "Squads"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "squads.refreshTree",
          "when": "view == squadsTree",
          "group": "navigation"
        },
        {
          "command": "squads.filterByType",
          "when": "view == squadsTree",
          "group": "1_squads"
        },
        {
          "command": "squads.filterByState",
          "when": "view == squadsTree",
          "group": "1_squads"
        },
        {
          "command": "squads.groupBy",
          "when": "view == squadsTree",
          "group": "1_squads"
        },
        {
          "command": "squads.clearFiltersAndGrouping",
          "when": "view == squadsTree",
          "group": "1_squads"
        }
      ]
    }
  },
  "scripts": {
    "vendor:mermaid": "node scripts/copy-mermaid.js",
    "compile": "npm run vendor:mermaid && tsc -p ./",
    "watch": "tsc -w -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:canary": "vitest run --config vitest.canary.config.ts",
    "test:e2e": "npm run compile && node ./out/test/extensionHost/runTest.js",
    "check": "npm run typecheck && npm run lint && npm run format:check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "mermaid": "^11.16.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
